# RASAD / re-dashboard environment template
# Copy this file to .env.local for local development.
# Never commit .env.local or real key values.

# Supabase project URL
# Example: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key for browser and server auth clients.
# This is NOT the service role key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project URL used by backend/ingestion scripts when needed.
SUPABASE_URL=

# Supabase service role key for ingestion/admin scripts only.
# Never expose this to browser/client code.
SUPABASE_SERVICE_ROLE_KEY=